<Window x:Class="CEB.Presentation.Views.ValidadeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Controle de Validade" Height="680" Width="1000"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0,0,4,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding"  Value="10,4"/>
            <Setter Property="Margin"   Value="0,2"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#00897B" Padding="16,10">
            <TextBlock Text="📅 Controle de Validade de Produtos"
                       Foreground="White" FontSize="15" FontWeight="Bold"/>
        </Border>

        <!-- Barra de filtros + legenda -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Filtros -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Label Content="Filtrar:"/>
                    <TextBox x:Name="TxtFiltro" Width="180"
                             TextChanged="TxtFiltro_TextChanged"/>
                    <Label Content="Exibir:" Margin="8,0,0,0"/>
                    <ComboBox x:Name="CboFiltroStatus" Width="160"
                              SelectionChanged="CboFiltroStatus_SelectionChanged"
                              SelectedIndex="0" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Todos"/>
                        <ComboBoxItem Content="Apenas válidos"/>
                        <ComboBoxItem Content="Vencidos"/>
                        <ComboBoxItem Content="A vencer (≤30 dias)"/>
                    </ComboBox>
                    <Button Content="↻ Atualizar" Click="BtnAtualizar_Click" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Legenda -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Border Width="12" Height="12" Background="#FFCDD2" CornerRadius="2" Margin="0,0,4,0"/>
                    <TextBlock Text="Vencido" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11"/>
                    <Border Width="12" Height="12" Background="#FFF9C4" CornerRadius="2" Margin="0,0,4,0"/>
                    <TextBlock Text="≤30 dias" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11"/>
                    <Border Width="12" Height="12" Background="#C8E6C9" CornerRadius="2" Margin="0,0,4,0"/>
                    <TextBlock Text="Válido" VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Formulário de cadastro de lote -->
        <GroupBox DockPanel.Dock="Top" Header="Cadastrar / Editar Lote" Padding="10,6" Margin="8,8,8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- label A -->
                    <ColumnDefinition Width="2*"/>    <!-- campo A (produto) -->
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>  <!-- label B -->
                    <ColumnDefinition Width="*"/>     <!-- campo B -->
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>  <!-- label C -->
                    <ColumnDefinition Width="0.7*"/>  <!-- campo C -->
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="96"/>    <!-- botões -->
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="34"/>
                </Grid.RowDefinitions>

                <!-- Linha 0: Produto | Nº Lote | Qtd -->
                <Label  Grid.Row="0" Grid.Column="0" Content="Produto *"/>
                <ComboBox x:Name="CboProduto" Grid.Row="0" Grid.Column="1"
                          DisplayMemberPath="Nome" SelectedValuePath="Id"
                          VerticalContentAlignment="Center"/>

                <Label  Grid.Row="0" Grid.Column="3" Content="Nº Lote *"/>
                <TextBox x:Name="TxtLote" Grid.Row="0" Grid.Column="4"/>

                <Label  Grid.Row="0" Grid.Column="6" Content="Qtd *"/>
                <TextBox x:Name="TxtQtd" Grid.Row="0" Grid.Column="7"/>

                <!-- Linha 2: Fabricação | Validade | Observação -->
                <Label  Grid.Row="2" Grid.Column="0" Content="Fabricação *"/>
                <DatePicker x:Name="DpFabricacao" Grid.Row="2" Grid.Column="1"/>

                <Label  Grid.Row="2" Grid.Column="3" Content="Validade *"/>
                <DatePicker x:Name="DpValidade" Grid.Row="2" Grid.Column="4"/>

                <Label  Grid.Row="2" Grid.Column="6" Content="Observação"/>
                <TextBox x:Name="TxtObservacao" Grid.Row="2" Grid.Column="7"/>

                <!-- Botões (span 3 linhas) -->
                <StackPanel Grid.Row="0" Grid.Column="9" Grid.RowSpan="3"
                            VerticalAlignment="Center">
                    <Button Content="Salvar" Background="#43A047" Foreground="White"
                            FontWeight="SemiBold" Click="BtnSalvarLote_Click"/>
                    <Button Content="Limpar" Click="BtnLimparLote_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Grid de lotes -->
        <DataGrid x:Name="DgLotes" Margin="8,0,8,8"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" CanUserAddRows="False"
                  SelectionChanged="DgLotes_SelectionChanged">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="Vencido">
                            <Setter Property="Background" Value="#FFCDD2"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="AVencer">
                            <Setter Property="Background" Value="#FFF9C4"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="Ok">
                            <Setter Property="Background" Value="#C8E6C9"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Código"         Binding="{Binding ProdutoCodigo}"                        Width="90"/>
                <DataGridTextColumn Header="Produto"        Binding="{Binding ProdutoNome}"                          Width="*"/>
                <DataGridTextColumn Header="Nº Lote"        Binding="{Binding Lote}"                                 Width="100"/>
                <DataGridTextColumn Header="Fabricação"     Binding="{Binding DataFabricacao, StringFormat=dd/MM/yyyy}" Width="95"/>
                <DataGridTextColumn Header="Validade"       Binding="{Binding DataValidade,   StringFormat=dd/MM/yyyy}" Width="95"/>
                <DataGridTextColumn Header="Dias p/ Vencer" Binding="{Binding DiasParaVencer}"                       Width="105"/>
                <DataGridTextColumn Header="Qtd"            Binding="{Binding Quantidade}"                           Width="65"/>
                <DataGridTextColumn Header="Un."            Binding="{Binding ProdutoUnidade}"                       Width="55"/>
                <DataGridTextColumn Header="Observação"     Binding="{Binding Observacao}"                           Width="140"/>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Editar lote"  Click="MenuEditarLote_Click"/>
                    <MenuItem Header="Excluir lote" Click="MenuExcluirLote_Click"/>
                    <Separator/>
                    <MenuItem Header="Gerar etiqueta de validade..." Click="MenuEtiquetaValidade_Click"/>
                    <Separator/>
                    <MenuItem Header="Ver histórico do produto..." Click="MenuHistoricoLote_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </DockPanel>
</Window>

