<Window x:Class="CEB.Presentation.Views.CadastroEnderecoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro de Endereço" Height="340" Width="480"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1976D2" Padding="16,10">
            <TextBlock x:Name="TxtTitulo" Text="Novo Endereço"
                       Foreground="White" FontSize="15" FontWeight="Bold"/>
        </Border>

        <!-- Footer com botões -->
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Salvar" Click="BtnSalvar_Click"
                        Background="#43A047" Foreground="White"
                        FontWeight="SemiBold" Padding="16,6" Margin="0,0,8,0" MinWidth="90"/>
                <Button Content="Cancelar" Click="BtnCancelar_Click"
                        Padding="16,6" MinWidth="90"/>
            </StackPanel>
        </Border>

        <!-- Formulário -->
        <ScrollViewer Padding="20,16" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Setor *"/>
                <TextBox x:Name="TxtSetor" Grid.Row="0" Grid.Column="1"
                         MaxLength="20" CharacterCasing="Upper"
                         ToolTip="Identificação do setor (ex: A, B, C)"/>

                <Label Grid.Row="2" Grid.Column="0" Content="Rua *"/>
                <TextBox x:Name="TxtRua" Grid.Row="2" Grid.Column="1"
                         MaxLength="20" CharacterCasing="Upper"
                         ToolTip="Número ou identificação da rua (ex: 01, 02)"/>

                <Label Grid.Row="4" Grid.Column="0" Content="Coluna *"/>
                <TextBox x:Name="TxtColuna" Grid.Row="4" Grid.Column="1"
                         MaxLength="20" CharacterCasing="Upper"
                         ToolTip="Número da coluna (ex: 03)"/>

                <Label Grid.Row="6" Grid.Column="0" Content="Nível *"/>
                <TextBox x:Name="TxtNivel" Grid.Row="6" Grid.Column="1"
                         MaxLength="20" CharacterCasing="Upper"
                         ToolTip="Nível ou andar da prateleira (ex: 1, 2, 3)"/>

                <!-- Preview do código gerado -->
                <Border Grid.Row="8" Grid.ColumnSpan="2"
                        Background="#E3F2FD" CornerRadius="4" Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Código do endereço: " VerticalAlignment="Center" Foreground="#555"/>
                        <TextBlock x:Name="TxtPreview" FontSize="16" FontWeight="Bold"
                                   Foreground="#1976D2" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
