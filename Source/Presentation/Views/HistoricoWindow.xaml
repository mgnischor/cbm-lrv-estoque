<Window x:Class="CEB.Presentation.Views.HistoricoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Histórico de Lançamentos" Height="640" Width="1120"
        MinWidth="800" MinHeight="420"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0,0,4,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding"  Value="10,4"/>
            <Setter Property="Margin"   Value="4,0"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#37474F" Padding="16,10">
            <TextBlock Text="🕓 Histórico de Lançamentos"
                       Foreground="White" FontSize="15" FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Filtros -->
        <Border DockPanel.Dock="Top" Background="#ECEFF1" BorderBrush="#B0BEC5"
                BorderThickness="0,0,0,1" Padding="10,8">
            <WrapPanel>
                <Label Content="Buscar:"/>
                <TextBox x:Name="TxtFiltro" Width="220" Padding="4,3"
                         VerticalContentAlignment="Center" Margin="0,0,8,0"
                         TextChanged="TxtFiltro_TextChanged"/>

                <Label Content="Tipo:" Margin="4,0,0,0"/>
                <ComboBox x:Name="CboTipo" Width="110" VerticalContentAlignment="Center"
                          Margin="0,0,8,0" SelectionChanged="CboTipo_SelectionChanged">
                    <ComboBoxItem Content="Todos" IsSelected="True"/>
                    <ComboBoxItem Content="Estoque"/>
                    <ComboBoxItem Content="Produto"/>
                    <ComboBoxItem Content="EPI"/>
                    <ComboBoxItem Content="Validade"/>
                </ComboBox>

                <Label Content="De:" Margin="4,0,0,0"/>
                <DatePicker x:Name="DpInicio" Width="115"
                            VerticalContentAlignment="Center" Margin="0,0,8,0"
                            SelectedDateChanged="Dp_DateChanged"/>

                <Label Content="Até:"/>
                <DatePicker x:Name="DpFim" Width="115"
                            VerticalContentAlignment="Center" Margin="0,0,8,0"
                            SelectedDateChanged="Dp_DateChanged"/>

                <Button Content="Limpar filtros" Click="BtnLimparFiltros_Click"
                        Background="#546E7A" Foreground="White" Margin="4,0,0,0"/>
            </WrapPanel>
        </Border>

        <!-- Rodapé / barra de status -->
        <Border DockPanel.Dock="Bottom" Background="#ECEFF1" BorderBrush="#B0BEC5"
                BorderThickness="0,1,0,0" Padding="10,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtStatus" VerticalAlignment="Center"
                           Foreground="#546E7A" FontSize="11"/>
                <Border Width="12" Height="12" Background="#E3F2FD" CornerRadius="2"
                        Margin="16,0,4,0"/>
                <TextBlock Text="Estoque" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11"/>
                <Border Width="12" Height="12" Background="#E8F5E9" CornerRadius="2" Margin="0,0,4,0"/>
                <TextBlock Text="Produto" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11"/>
                <Border Width="12" Height="12" Background="#FFF3E0" CornerRadius="2" Margin="0,0,4,0"/>
                <TextBlock Text="EPI" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="11"/>
                <Border Width="12" Height="12" Background="#F3E5F5" CornerRadius="2" Margin="0,0,4,0"/>
                <TextBlock Text="Validade" VerticalAlignment="Center" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- DataGrid de histórico -->
        <DataGrid x:Name="DgHistorico" Margin="8"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" AlternatingRowBackground="#F5F5F5"
                  CanUserAddRows="False" GridLinesVisibility="Horizontal">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <!-- Estoque: entrada (verde), saída (vermelho), ajuste (amarelo) -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Tipo}" Value="Estoque"/>
                                <Condition Binding="{Binding Acao}" Value="Entrada"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#E8F5E9"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Tipo}" Value="Estoque"/>
                                <Condition Binding="{Binding Acao}" Value="Saída"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#FFEBEE"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Tipo}" Value="Estoque"/>
                                <Condition Binding="{Binding Acao}" Value="Ajuste"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#E3F2FD"/>
                        </MultiDataTrigger>
                        <!-- Produto -->
                        <DataTrigger Binding="{Binding Tipo}" Value="Produto">
                            <Setter Property="Background" Value="#F1F8E9"/>
                        </DataTrigger>
                        <!-- EPI -->
                        <DataTrigger Binding="{Binding Tipo}" Value="EPI">
                            <Setter Property="Background" Value="#FFF3E0"/>
                        </DataTrigger>
                        <!-- Validade -->
                        <DataTrigger Binding="{Binding Tipo}" Value="Validade">
                            <Setter Property="Background" Value="#F3E5F5"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Data / Hora"
                                    Binding="{Binding DataHora, StringFormat=dd/MM/yyyy HH:mm:ss}"
                                    Width="140"/>
                <DataGridTextColumn Header="Tipo"       Binding="{Binding Tipo}"       Width="80"/>
                <DataGridTextColumn Header="Ação"       Binding="{Binding Acao}"       Width="100"/>
                <DataGridTextColumn Header="Código"     Binding="{Binding Codigo}"     Width="100"/>
                <DataGridTextColumn Header="Nome"       Binding="{Binding Nome}"       Width="*"/>
                <DataGridTextColumn Header="Quantidade" Binding="{Binding Quantidade}" Width="90"/>
                <DataGridTextColumn Header="Detalhes"   Binding="{Binding Detalhes}"   Width="220"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
