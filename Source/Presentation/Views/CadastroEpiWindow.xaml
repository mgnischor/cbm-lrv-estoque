<Window x:Class="CEB.Presentation.Views.CadastroEpiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro de EPI" Height="540" Width="600"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#E65100" Padding="16,10">
            <TextBlock x:Name="TxtTituloJanela" Text="Novo EPI"
                       Foreground="White" FontSize="15" FontWeight="Bold"/>
        </Border>

        <!-- Botões rodapé -->
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5" BorderBrush="#BDBDBD"
                BorderThickness="0,1,0,0" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Salvar" Width="90" Margin="0,0,8,0"
                        Background="#43A047" Foreground="White"
                        Click="BtnSalvar_Click" IsDefault="True"/>
                <Button Content="Cancelar" Width="90" IsCancel="True"
                        Click="BtnCancelar_Click"/>
            </StackPanel>
        </Border>

        <!-- Formulário -->
        <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="36"/>
                </Grid.RowDefinitions>

                <!-- Código -->
                <Label Grid.Row="0" Grid.Column="0" Content="Código *"/>
                <TextBox x:Name="TxtCodigo" Grid.Row="0" Grid.Column="1"
                         Grid.ColumnSpan="3" Margin="0,4"/>

                <!-- Nome -->
                <Label Grid.Row="1" Grid.Column="0" Content="Nome *"/>
                <TextBox x:Name="TxtNome" Grid.Row="1" Grid.Column="1"
                         Grid.ColumnSpan="3" Margin="0,4"/>

                <!-- Número CA / Validade CA -->
                <Label Grid.Row="2" Grid.Column="0" Content="Nº CA *"
                       ToolTip="Número do Certificado de Aprovação"/>
                <TextBox x:Name="TxtNumeroCa" Grid.Row="2" Grid.Column="1"
                         Margin="0,4,8,4"/>

                <Label Grid.Row="2" Grid.Column="2" Content="Validade CA *"/>
                <DatePicker x:Name="DpValidadeCa" Grid.Row="2" Grid.Column="3"
                            Margin="0,4"/>

                <!-- Quantidade / Estado de conservação -->
                <Label Grid.Row="3" Grid.Column="0" Content="Quantidade *"/>
                <TextBox x:Name="TxtQuantidade" Grid.Row="3" Grid.Column="1"
                         Margin="0,4,8,4"/>

                <Label Grid.Row="3" Grid.Column="2" Content="Conservação *"/>
                <ComboBox x:Name="CboEstadoConservacao" Grid.Row="3" Grid.Column="3"
                          Margin="0,4">
                    <ComboBoxItem Content="Ótimo"/>
                    <ComboBoxItem Content="Bom" IsSelected="True"/>
                    <ComboBoxItem Content="Regular"/>
                    <ComboBoxItem Content="Danificado"/>
                    <ComboBoxItem Content="Descartado"/>
                </ComboBox>

                <!-- Responsável -->
                <Label Grid.Row="4" Grid.Column="0" Content="Responsável"/>
                <TextBox x:Name="TxtResponsavel" Grid.Row="4" Grid.Column="1"
                         Grid.ColumnSpan="3" Margin="0,4"
                         ToolTip="Nome do responsável pela guarda/uso do EPI"/>

                <!-- Setor -->
                <Label Grid.Row="5" Grid.Column="0" Content="Setor / Local"/>
                <TextBox x:Name="TxtSetor" Grid.Row="5" Grid.Column="1"
                         Grid.ColumnSpan="3" Margin="0,4"/>

                <!-- Descrição -->
                <Label Grid.Row="6" Grid.Column="0" Content="Descrição"
                       VerticalAlignment="Top" Margin="0,6,4,0"/>
                <TextBox x:Name="TxtDescricao" Grid.Row="6" Grid.Column="1"
                         Grid.ColumnSpan="3" Margin="0,4"/>

                <!-- Observação -->
                <Label Grid.Row="7" Grid.Column="0" Content="Observação"
                       VerticalAlignment="Top" Margin="0,8,4,0"/>
                <TextBox x:Name="TxtObservacao" Grid.Row="7" Grid.Column="1"
                         Grid.ColumnSpan="3" Margin="0,4"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Aviso -->
                <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="4"
                           Text="* Campos obrigatórios" Foreground="#9E9E9E"
                           FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
