<Window x:Class="CEB.Presentation.Views.CadastroProdutoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro de Produto" Height="420" Width="560"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1976D2" Padding="16,10">
            <TextBlock x:Name="TxtTituloJanela" Text="Novo Produto"
                       Foreground="White" FontSize="15" FontWeight="Bold"/>
        </Border>

        <!-- Botões rodapé -->
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5" BorderBrush="#BDBDBD"
                BorderThickness="0,1,0,0" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Salvar" Width="90" Margin="0,0,8,0"
                        Background="#43A047" Foreground="White"
                        Click="BtnSalvar_Click" IsDefault="True"/>
                <Button Content="Cancelar" Width="90" IsCancel="True"
                        Click="BtnCancelar_Click"/>
            </StackPanel>
        </Border>

        <!-- Formulário -->
        <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="36"/>
                </Grid.RowDefinitions>

                <!-- Código -->
                <Label Grid.Row="0" Grid.Column="0" Content="Código *"/>
                <TextBox x:Name="TxtCodigo" Grid.Row="0" Grid.Column="1"
                         Grid.ColumnSpan="3" Margin="0,4"/>

                <!-- Nome -->
                <Label Grid.Row="1" Grid.Column="0" Content="Nome *"/>
                <TextBox x:Name="TxtNome" Grid.Row="1" Grid.Column="1"
                         Grid.ColumnSpan="3" Margin="0,4"/>

                <!-- Unidade / Categoria -->
                <Label Grid.Row="2" Grid.Column="0" Content="Unidade *"/>
                <TextBox x:Name="TxtUnidade" Grid.Row="2" Grid.Column="1" Margin="0,4,8,4"/>

                <Label Grid.Row="2" Grid.Column="2" Content="Categoria"/>
                <TextBox x:Name="TxtCategoria" Grid.Row="2" Grid.Column="3" Margin="0,4"/>

                <!-- Patrimônio -->
                <Label Grid.Row="3" Grid.Column="0" Content="Patrimônio"/>
                <TextBox x:Name="TxtPatrimonio" Grid.Row="3" Grid.Column="1"
                         Grid.ColumnSpan="3" Margin="0,4"
                         ToolTip="Número de patrimônio (opcional)"/>

                <!-- Descrição -->
                <Label Grid.Row="4" Grid.Column="0" Content="Descrição"
                       VerticalAlignment="Top" Margin="0,8,4,0"/>
                <TextBox x:Name="TxtDescricao" Grid.Row="4" Grid.Column="1"
                         Grid.ColumnSpan="3" Margin="0,4"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Aviso campos obrigatórios -->
                <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4"
                           Text="* Campos obrigatórios" Foreground="#9E9E9E"
                           FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
